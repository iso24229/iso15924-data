{
  "name": "@iso24229/iso15924-data",
  "type": "module",
  "version": "0.2.0",
  "description": "Auto-synced reference data for ISO 15924 (script codes)",
  "repository": {
    "type": "git",
    "url": "https://github.com/iso24229/iso15924-data.git"
  },
  "main": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "sync": "node scripts/sync.mjs",
    "validate": "node scripts/validate.mjs"
  },
  "files": [
    "codes",
    "schema",
    "manifest.yaml",
    "last-checked-date.txt",
    "README.adoc",
    "index.mjs",
    "index.d.ts"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
